{
  "name": "@caliber/jobs",
  "private": true,
  "type": "module",
  "workspaces": [
    ".",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite dev --port 3003",
    "build": "vite build",
    "serve": "wrangler dev",
    "type-check": "tsc --noEmit",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "test:ui": "vitest --ui -c vitest.config.ts",
    "test:coverage": "vitest run --coverage -c vitest.config.ts",
    "lint:types": "tsc --noEmit --pretty",
    "preview": "npm run build && wrangler dev",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "data:migrate:job-analyzer": "node scripts/migrate-job-analyzer-data.mjs",
    "seed:vectors": "node scripts/seed-vector-index.mjs",
    "seed:vectors:prod": "node scripts/seed-vector-index.mjs --prod",
    "db:studio": "drizzle-kit studio",
    "deploy:sync": "wrangler deploy --config wrangler.sync.toml",
    "deploy:ats": "wrangler deploy --config wrangler.ats.toml",
    "deploy:discovery": "wrangler deploy --config wrangler.discovery.toml",
    "deploy:workers": "npm run deploy:ats && npm run deploy:discovery",
    "deploy": "npm run build && wrangler deploy --config wrangler.toml"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^0.0.15",
    "@cloudflare/vite-plugin": "^1.42.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/pacer": "^0.16.3",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-pacer": "^0.18.0",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.11",
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.1.0",
    "jsonrepair": "^3.13.3",
    "lucide-react": "^0.545.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.7",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260430.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.19.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.7",
    "typescript": "^5.7.2",
    "vite": "^8.0.1",
    "vitest": "^3.0.5",
    "wrangler": "^4.102.0"
  }
}
